# Your deployer wallet private key (no 0x prefix needed)
PRIVATE_KEY=your_private_key_here

# Somnia testnet RPC (default already set in hardhat.config.ts)
RPC_URL=https://api.infra.testnet.somnia.network

# ── Filled automatically by scripts/deploy.ts ──────────────────────────────
# SYBIL_REGISTRY=0x...
# VESTING_VAULT=0x...
# LAUNCH_POOL=0x...
# MOCK_TOKEN=0x...
