{
  "name": "vera-launch",
  "version": "1.0.0",
  "description": "AI-verified anti-Sybil launchpad with milestone-gated vesting on Somnia Agentic L1",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.ts --network somnia",
    "sybil:check": "hardhat run scripts/sybil/requestCheck.ts --network somnia",
    "vesting:create": "hardhat run scripts/vesting/createSchedule.ts --network somnia",
    "vesting:claim": "hardhat run scripts/vesting/claimMilestone.ts --network somnia",
    "launch:create": "hardhat run scripts/launch/createPool.ts --network somnia",
    "launch:participate": "hardhat run scripts/launch/participate.ts --network somnia",
    "launch:finalize": "hardhat run scripts/launch/finalizePool.ts --network somnia",
    "launch:claim": "hardhat run scripts/launch/claimOrRefund.ts --network somnia",
    "monitor": "hardhat run scripts/monitor/eventListener.ts --network somnia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "5.0.0",
    "@nomicfoundation/hardhat-viem": "2.0.6",
    "hardhat": "^2.28.0",
    "typescript": "5.8.3",
    "ts-node": "10.9.2",
    "dotenv": "16.5.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0"
  }
}
